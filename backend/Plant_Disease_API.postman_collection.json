{
  "info": {
    "name": "🌿 Plant Disease Detection API",
    "description": "Complete API collection for the Plant Disease Detection backend.\n\n## Setup\n1. Set the `base_url` variable to your server (default: http://127.0.0.1:5000)\n2. Run **Register** or **Login** first — the token is auto-saved\n3. All authenticated requests use the token automatically\n\n## Workflow\n1. Register → Login\n2. Upload Scan (with image)\n3. View History / Scan Detail\n4. Browse Diseases\n5. View/Edit Profile",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "scan_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "disease_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Authentication endpoints — register, login, and get current user.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('user_id', json.user.id);",
                  "    pm.test('Registration successful', function () {",
                  "        pm.expect(json.user).to.have.property('id');",
                  "        pm.expect(json).to.have.property('token');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"displayName\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Create a new user account.\n\n**Validation:**\n- `displayName`: min 2 characters\n- `email`: valid email format, must be unique\n- `password`: min 6 characters\n\n**Auto-saves** the JWT token for subsequent requests."
          },
          "response": [
            {
              "name": "201 — Success",
              "status": "Created",
              "code": 201,
              "body": "{\n    \"user\": {\n        \"id\": \"6655...\",\n        \"email\": \"john@example.com\",\n        \"displayName\": \"John Doe\",\n        \"role\": \"user\",\n        \"createdAt\": \"...\",\n        \"lastLoginAt\": \"...\"\n    },\n    \"token\": \"eyJhbGci...\"\n}"
            },
            {
              "name": "409 — Email exists",
              "status": "Conflict",
              "code": 409,
              "body": "{\n    \"error\": \"Email already registered\"\n}"
            },
            {
              "name": "400 — Validation error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n    \"error\": \"Valid email is required\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('user_id', json.user.id);",
                  "    pm.test('Login successful', function () {",
                  "        pm.expect(json).to.have.property('token');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate and receive a JWT token (valid for 72 hours).\n\n**Auto-saves** the JWT token for subsequent requests."
          },
          "response": [
            {
              "name": "200 — Success",
              "status": "OK",
              "code": 200,
              "body": "{\n    \"user\": { \"id\": \"...\", \"email\": \"...\", \"displayName\": \"...\" },\n    \"token\": \"eyJhbGci...\"\n}"
            },
            {
              "name": "401 — Invalid credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n    \"error\": \"Invalid email or password\"\n}"
            }
          ]
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Got current user', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get the currently authenticated user's info.\n\nRequires a valid JWT in the Authorization header."
          },
          "response": [
            {
              "name": "200 — Success",
              "status": "OK",
              "code": 200,
              "body": "{\n    \"user\": {\n        \"id\": \"...\",\n        \"email\": \"john@example.com\",\n        \"displayName\": \"John Doe\",\n        \"role\": \"user\"\n    }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "📸 Scans",
      "description": "Scan endpoints — upload plant images for AI diagnosis, view history.",
      "item": [
        {
          "name": "Upload Scan (AI Diagnosis)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('scan_id', json.scan.id);",
                  "    pm.test('Scan created with diagnosis', function () {",
                  "        pm.expect(json.scan).to.have.property('id');",
                  "        pm.expect(json.prediction).to.have.property('className');",
                  "        pm.expect(json.prediction).to.have.property('confidence');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Select a plant leaf image (JPG/PNG)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/scans",
              "host": ["{{base_url}}"],
              "path": ["api", "scans"]
            },
            "description": "Upload a plant leaf image for AI-powered disease detection.\n\n**Flow:**\n1. Image is uploaded to storage (Cloudinary or local)\n2. AI model runs inference (38 classes)\n3. Scan + Diagnosis records are saved to DB\n4. Full result returned with disease details\n\n**Body:** `multipart/form-data` with field `image`"
          },
          "response": [
            {
              "name": "201 — Diagnosis complete",
              "status": "Created",
              "code": 201,
              "body": "{\n    \"scan\": { \"id\": \"...\", \"imageUrl\": \"...\", \"status\": \"completed\" },\n    \"diagnosis\": { \"confidence\": 0.9723, \"isHealthy\": false },\n    \"prediction\": {\n        \"className\": \"Tomato___Late_blight\",\n        \"plantName\": \"Tomato\",\n        \"diseaseName\": \"Late blight\",\n        \"confidence\": 0.9723,\n        \"isHealthy\": false\n    },\n    \"disease\": {\n        \"name\": \"Tomato___Late_blight\",\n        \"description\": \"...\",\n        \"treatment\": \"...\"\n    }\n}"
            }
          ]
        },
        {
          "name": "List Scan History",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Got scan list', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('scans');",
                  "    pm.expect(json).to.have.property('total');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/scans?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "scans"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "per_page",
                  "value": "20",
                  "description": "Items per page (default: 20)"
                }
              ]
            },
            "description": "Get paginated scan history for the current user.\n\nEach scan includes its diagnosis and disease details."
          },
          "response": [
            {
              "name": "200 — Success",
              "status": "OK",
              "code": 200,
              "body": "{\n    \"scans\": [\n        {\n            \"id\": \"...\",\n            \"imageUrl\": \"...\",\n            \"status\": \"completed\",\n            \"createdAt\": \"...\",\n            \"diagnosis\": { \"confidence\": 0.95, \"isHealthy\": false },\n            \"disease\": { \"name\": \"...\", \"description\": \"...\" }\n        }\n    ],\n    \"total\": 5,\n    \"page\": 1,\n    \"perPage\": 20\n}"
            }
          ]
        },
        {
          "name": "Get Scan Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Got scan detail', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.scan).to.have.property('id');",
                  "    pm.expect(json.scan).to.have.property('diagnosis');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/scans/{{scan_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "scans", "{{scan_id}}"]
            },
            "description": "Get full details for a specific scan.\n\nIncludes: scan info, diagnosis, disease details, and plant info.\n\n**Access:** Owner only (or admin)."
          },
          "response": [
            {
              "name": "200 — Success",
              "status": "OK",
              "code": 200,
              "body": "{\n    \"scan\": {\n        \"id\": \"...\",\n        \"imageUrl\": \"...\",\n        \"diagnosis\": { \"confidence\": 0.97 },\n        \"disease\": { \"name\": \"...\", \"treatment\": \"...\" },\n        \"plant\": { \"commonName\": \"Tomato\" }\n    }\n}"
            }
          ]
        }
      ]
    },
